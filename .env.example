# Deepgram API key (https://console.deepgram.com → API Keys)
DEEPGRAM_API_KEY=your_deepgram_key

# Groq API key (https://console.groq.com → API Keys)
GROQ_API_KEY=your_groq_key

# Chunking config
MAX_CHUNK_MINUTES=8
OVERLAP_SECONDS=30

# Paths (relative to backend/)
TEMP_DIR=./temp
JOBS_DIR=./jobs

# CORS — add your VPS IP or domain for production
CORS_ORIGINS=["http://localhost:5173","http://localhost","http://YOUR_VPS_IP"]

# Frontend API URL — set to your backend's public URL for production
# Leave as empty string or omit for local dev (falls back to localhost:8000)
VITE_API_URL=
